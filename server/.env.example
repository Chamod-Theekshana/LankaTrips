# Server
NODE_ENV=development
PORT=5001
CLIENT_URL=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/lankatrips

# JWT
JWT_SECRET=replace_me_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Uploads (local)
UPLOAD_DIR=uploads

# Currency
DEFAULT_CURRENCY=LKR

# (Optional) Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
